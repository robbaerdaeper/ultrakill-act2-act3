"UnlitGeneric"
{
	"$basetexture"     "effects/uktest_sand"
	"$model"           "1"
	"$translucent"     "1"
	"$color2"          "[4 2 1]"
	"$nodecal"         "1"
	"$nocull"          "1"
	"$pointsamplemagfilter" "1"
	"$nomip"           "1"
	"$nolod"           "1"

	"$OffsetVar"       "0"
	"$CenterVar"       "[.5 .5]"
	"$ScaleVar"        "[1 1]"
	"$TranslateVar"    "[0 0]"
	"$RotateVar"       "0"

	Proxies
	{
		EntityRandom
		{
			scale 1
			resultVar $OffsetVar
		}

		LinearRamp
		{
			rate 0.05
			initialvalue $OffsetVar
			resultvar "$TranslateVar[0]"
		}

		LinearRamp
		{
			rate 0.05
			initialvalue $OffsetVar
			resultvar "$TranslateVar[1]"
		}

		TextureTransform
		{
			centervar $CenterVar
			scalevar $ScaleVar
			rotatevar $RotateVar
			translatevar $TranslateVar
			resultvar $basetexturetransform
		}
	}
}
