// runs along the beam U axis for render.DrawBeam.
"UnlitGeneric"
{
	"$basetexture" "effects/ukferryman_bolt"
	"$additive" "1"
	"$vertexcolor" "1"
	"$vertexalpha" "1"
	"$nocull" "1"
	"$ignorez" "0"
}
