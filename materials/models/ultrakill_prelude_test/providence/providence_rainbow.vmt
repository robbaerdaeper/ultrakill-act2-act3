"UnlitGeneric"
{
	"$basetexture" "models/ultrakill_prelude_test/providence/providence_rainbow"
	"$model" 1
	"$nocull" 1
	"$pointsamplemagfilter" 1
	"$additive" 1
	"$translucent" 1
	"$alpha" "0.75"
	"Proxies"
	{
		"TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" "0.05"
			"texturescrollangle" "0"
		}
	}
}
