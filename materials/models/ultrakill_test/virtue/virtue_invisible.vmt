// Невидимый материал: additive + чёрный цвет = ничего не добавляет к кадру.
// Используется трупом Virtue, чтобы скрыть золотую оболочку (крест/корона/цепи),
// оставив только сферу-ядро.
"UnlitGeneric"
{
    "$basetexture" "vgui/white"
    "$additive"    "1"
    "$translucent" "1"
    "$color"       "[0 0 0]"
    "$nocull"      "1"
}
