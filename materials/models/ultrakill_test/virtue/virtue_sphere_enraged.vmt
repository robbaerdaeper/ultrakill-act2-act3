// Enraged оболочка-шар = КАНОННАЯ divine_enraged_sphere: полупрозрачная КРАСНАЯ,
// selfillum + красный rimlight (как в игре). НЕ additive (тот делал сферу невидимой на
// почти-белой текстуре) и НЕ чёрная. Ядро — отдельный материал virtue_core, тут не трогается,
// поэтому VertexLit-затемнение сферы ему больше не грозит.
"VertexLitGeneric"
{
    "$basetexture"           "models/ultrakill_test/virtue/divine_enraged_sphere"
    "$selfillum"             "1"
    "$translucent"           "1"
    "$nocull"                "1"
    "$rimlight"              "1"
    "$rimlightexponent"      "4"
    "$rimlightboost"         "2"
    "$rimlighttint"          "[1 0 0]"
    "$color2"                "[1 0.3 0.3]"
    "$nodecal"               "1"
}
