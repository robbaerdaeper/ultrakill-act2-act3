// Ferryman — rigged canon model (2026-07-02 full port).
// SMD sources: ferryman_build_ref_mesh.py (mesh, exact bind skinning via UnityPy)
//              ferryman_bake_anims.py (skeleton + 15 canon clips, 30 fps)
// Scale: bone-space unit -> su. Calibration: 1 canon meter = 0.003447 bone units,
// project convention 40 su/m  =>  $scale = 40 / 0.003447 = 11604.
$modelname "ultrakill_prelude_test/ferryman.mdl"
$upaxis Y
// NB: the AssetStudio FBX is a SCENE INSTANCE (Ferryman_#1702042) whose baked
// world yaw leaves the SMD facing +Z (virtue_v2 convention), not +X (stalker).
// $origin yaw 90 = neutral (+X-forward data), 0 = rotate -90 for +Z-forward data.
$origin 0 0 0 0
$scale 7020.0 // 2026-07-10 r3: ещё +10% (итог x0.605 от 11604)

$bodygroup "body" {
    studio "ferryman_body_ref.smd"
}
// canon: Enemy.onDeath -> Oar.SetActive(false); Lua hides this bodygroup on death
$bodygroup "oar" {
    studio "ferryman_oar_ref.smd"
    blank
}

$cdmaterials "models/ultrakill_prelude_test/ferryman/"

// skin 1 = charged oar during lightning windup (canon chargedOar material swap)
$texturegroup "skinfamilies" {
    { "ferryman_oar" }
    { "ferryman_oar_charged" }
}

$surfaceprop "flesh"
$contents "solid"

// all materials are UnlitGeneric (lighting ignored); zero like gutterman.
// NB: $illumposition is multiplied by $scale — never pass su values here.
$illumposition 0 0 0

$attachment "head"  "Head"     0 0 0
$attachment "chest" "Spine_03" 0 0 0
$attachment "oar"   "Oar_Bone" 0 0 0

$sequence Idle               "idle"               loop fps 30
$sequence Run                "run"                loop fps 30
$sequence Falling            "falling"            loop fps 30
$sequence Downslam           "downslam"                fps 30
$sequence Stinger            "stinger"                 fps 30
$sequence Uppercut           "uppercut"                fps 30
$sequence Roll               "roll"                    fps 30
$sequence BackstepAttack     "backstepattack"          fps 30
$sequence KickCombo          "kickcombo"               fps 30
$sequence VaultSwing         "vaultswing"              fps 30
$sequence Vault              "vault"                   fps 30
$sequence OarCombo           "oarcombo"                fps 30
$sequence LightningBolt      "lightningbolt"           fps 30
$sequence QuickLightningBolt "quicklightningbolt"      fps 30
$sequence Knockdown          "knockdown"               fps 30

// Jointed ragdoll phys (2026-07-07): 11 convex pieces from the real body mesh,
// generated by ferryman_build_ragdoll_phys.py (halo + robe skirt
// flaps excluded from collision; oar is a bodygroup and never ragdolls).
// Spine_02 got no dominant verts -> no piece; Spine_03 joints onto Spine_01.
// The live NPC still collides via DrGBase CollisionBounds; this phys exists so
// util.IsValidRagdoll passes and death spawns a real prop_ragdoll.
$collisionjoints "ferryman_ragdoll_phys.smd" {
    $mass 400
    $inertia 10
    $damping 0.01
    $rotdamping 1.5
    $rootbone "Spine_01"
    $noselfcollisions

    $jointconstrain "Spine_03" x limit -30 30 0
    $jointconstrain "Spine_03" y limit -30 30 0
    $jointconstrain "Spine_03" z limit -30 30 0

    $jointconstrain "Head" x limit -45 45 0
    $jointconstrain "Head" y limit -45 45 0
    $jointconstrain "Head" z limit -45 45 0

    $jointconstrain "Upperarm_Left" x limit -80 80 0
    $jointconstrain "Upperarm_Left" y limit -80 80 0
    $jointconstrain "Upperarm_Left" z limit -80 80 0

    $jointconstrain "Forearm_Left" x limit -20 20 0
    $jointconstrain "Forearm_Left" y limit -20 20 0
    $jointconstrain "Forearm_Left" z limit -120 10 0

    $jointconstrain "Upperarm_Right" x limit -80 80 0
    $jointconstrain "Upperarm_Right" y limit -80 80 0
    $jointconstrain "Upperarm_Right" z limit -80 80 0

    $jointconstrain "Forearm_Right" x limit -20 20 0
    $jointconstrain "Forearm_Right" y limit -20 20 0
    $jointconstrain "Forearm_Right" z limit -10 120 0

    $jointconstrain "Thigh_Left" x limit -70 70 0
    $jointconstrain "Thigh_Left" y limit -70 70 0
    $jointconstrain "Thigh_Left" z limit -70 70 0

    $jointconstrain "Calf_Left" x limit -15 15 0
    $jointconstrain "Calf_Left" y limit -15 15 0
    $jointconstrain "Calf_Left" z limit -10 120 0

    $jointconstrain "Thigh_Right" x limit -70 70 0
    $jointconstrain "Thigh_Right" y limit -70 70 0
    $jointconstrain "Thigh_Right" z limit -70 70 0

    $jointconstrain "Calf_Right" x limit -15 15 0
    $jointconstrain "Calf_Right" y limit -15 15 0
    $jointconstrain "Calf_Right" z limit -120 10 0
}
